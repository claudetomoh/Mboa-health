# Apache configuration for Mboa Health API
# Apache 2.4 — AllowOverride: FileInfo AuthConfig Limit Indexes

# Disable directory listings (OWASP A05)
Options -Indexes

# ── Block direct HTTP access to sensitive files (Apache 2.4) ─────────────────
<FilesMatch "^(config|config\.example|db|helpers)\.php$|^schema\.sql$">
    Require all denied
</FilesMatch>
